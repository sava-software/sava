# Exclude everything by default.
/*

# Explicitly include tracked files and directories.
!/.dockerignore
!/.github/
!/.gitignore
!/.release-please-manifest.json
!/CHANGELOG.md
!/LICENSE
!/README.md
!/assets/
!/gradle/
!/gradle.properties
!/gradlew
!/gradlew.bat
!/jmh/
!/logging.properties
!/release-please-config.json
!/sava-*/
!/settings.gradle.kts
!AGENTS.md
!AGAVE_SYNC.md
!CONVENTIONS.md
!HARDENING_NOTES.md

# Re-apply ignores within included directories.
.gradle
.kotlin
build/
gradle-app.setting
.gradletasknamecache
*.class
*.log
*.ctxt
.mtj.tmp/
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.war
*.ear
*.tar.gz
*.rar
hs_err_pid*
*.iml
.idea
out/
*.secret
.DS_Store
ignore
.keys
keys
Integ.*
integ.*

# arcmutate incremental-analysis state — machine local, survives clean
.pitest-history/
